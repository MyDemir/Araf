# Araf Protocol Smart Contract Environment Variables
# Copy this file to .env for local use.
# Never commit real .env values.

# Required deployer wallet key. Keep the 0x prefix.
DEPLOYER_PRIVATE_KEY="0x_REPLACE_WITH_DEPLOYER_KEY"

# Contract owner / treasury address after deploy.
TREASURY_ADDRESS="0x_REPLACE_WITH_TREASURY_ADDRESS"

# RPC endpoints
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
BASE_RPC_URL="https://mainnet.base.org"

# Token addresses
# Base Sepolia strategy:
# - USDT is not officially supported on Base Sepolia; deploy.js deploys MockUSDT.
# - USDC uses Circle's official Base Sepolia testnet token address.
BASE_SEPOLIA_USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# Base Mainnet real token addresses
MAINNET_USDT_ADDRESS="0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2"
MAINNET_USDC_ADDRESS="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"

# Optional verification / gas reporting
BASESCAN_API_KEY="REPLACE_WITH_BASESCAN_API_KEY"
REPORT_GAS="true"
CMC_API_KEY="REPLACE_WITH_COINMARKETCAP_API_KEY"
