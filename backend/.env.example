# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/araf_protocol

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
# Minimum 64 karakter zorunlu.
# Uretmek icin: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Bu degeri her deploy'da degistirmeyin; degisirse mevcut oturumlar gecersiz olur.
JWT_SECRET=BURAYA_CRYPTO_RANDOM_BYTES_64_ILE_URETILMIS_HEX_YAPISTIRINIZ
JWT_EXPIRES_IN=15m
FRAME_TOKEN_EXPIRES_IN=5m
PII_TOKEN_EXPIRES_IN=15m

# Encryption
# Base Sepolia public testnet icin KMS_PROVIDER=env kullanilabilir.
# Base Mainnet icin KMS_PROVIDER=aws veya vault zorunlu olmalidir.
# MASTER_ENCRYPTION_KEY 32 byte / 64 hex karakter olmalidir.
# Uretmek icin: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KMS_PROVIDER=env
MASTER_ENCRYPTION_KEY=BURAYA_CRYPTO_RANDOM_BYTES_32_ILE_URETILMIS_HEX_YAPISTIRINIZ

# AWS KMS mainnet ornegi
# KMS_PROVIDER=aws
# AWS_KMS_KEY_ARN=arn:aws:kms:eu-west-1:123456789:key/xxx-xxx-xxx
# AWS_ENCRYPTED_DATA_KEY=<base64-encoded-CiphertextBlob>
# AWS_REGION=eu-west-1

# Vault mainnet alternatifi
# KMS_PROVIDER=vault
# VAULT_ADDR=https://vault.araf.xyz:8200
# VAULT_TOKEN=<vault-token>
# VAULT_KEY_NAME=araf-master-key

# Base Network
# Public testnet: Base Sepolia
BASE_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# WebSocket RPC gercek zamanli event dinleme icin onerilir.
# Base Sepolia Alchemy ornegi: wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_WS_RPC_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

ARAF_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
CHAIN_ID=84532

# Worker checkpoint yoksa buradan baslar.
# GitHub Actions deploy.js ciktisindan otomatik set eder.
ARAF_DEPLOYMENT_BLOCK=0

# Event queryFilter isteklerinde tek sorguda taranacak maksimum blok araligi.
EVENT_QUERY_BLOCK_RANGE=10

# Protocol
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Relayer
# Bu cuzdani sadece testnet automation icin dusuk bakiyeli ayri bir wallet olarak kullanin.
# Uretmek icin: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
RELAYER_PRIVATE_KEY=0x_BURAYA_AYRI_BIR_CUZDAN_ANAHTARI_EKLE

# SIWE
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:5173
SIWE_CHAIN_ID=84532

# Miniapp/cross-site iframe akisinda production icin none + HTTPS gerekir.
# Degerler: lax | strict | none
COOKIE_SAMESITE=lax

# CORS
ALLOWED_ORIGINS=http://localhost:5173
