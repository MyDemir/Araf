# ─── Araf Protocol Frontend Environment Variables ─────────────────────
# Tanımsız bırakılırsa uygulama uyarı banner'ı gösterir.

# Backend API URL'si — production'da gerçek API domain'i yazın
# Development'ta boş bırakılabilir (localhost:4000 fallback kullanılır)
# NOT: Vercel deploy'da vercel.json /api/* proxy devreye girer, bu değişkene gerek kalmaz
VITE_API_URL=http://localhost:4000

# Deploy edilen kontrat adresi — deploy.js çıktısından kopyalayın
# Sıfır adres veya boş bırakılırsa kontrat işlemleri çalışmaz
VITE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-20 token adresleri
# Local geliştirmede deploy.js çıktısındaki MockUSDT / MockUSDC adreslerini girin.
# Base Sepolia testnet'te USDT için resmi Tether desteği yoktur; testnet akışında USDC tercih edilmelidir.
# Base Sepolia USDC için Circle faucet kullanılmalıdır.
VITE_USDT_ADDRESS=
VITE_USDC_ADDRESS=

# Base Sepolia testnet USDC yönlendirme butonu için resmi faucet URL'i.
# Boş bırakılırsa frontend varsayılan olarak https://faucet.circle.com/ kullanır.
VITE_TESTNET_USDC_FAUCET_URL=https://faucet.circle.com/
